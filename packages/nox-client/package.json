{
  "name": "@hisoka-io/nox-client",
  "version": "0.1.8",
  "description": "TypeScript client SDK for the NOX mixnet - anonymous DeFi transactions and HTTP proxying",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hisoka-io/nox-sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "e2e": "bash tests/internal/run_e2e.sh",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hisoka-io/nox-wasm": "^0.1.1",
    "js-sha3": "^0.9.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ethers": "^6.16.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}