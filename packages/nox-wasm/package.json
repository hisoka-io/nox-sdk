{
  "name": "@hisoka-io/nox-wasm",
  "version": "0.1.4",
  "description": "WASM bindings for NOX mixnet Sphinx cryptography",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hisoka-io/nox-sdk"
  },
  "scripts": {
    "build": "pnpm build:web && pnpm build:bundler && pnpm build:node",
    "build:web": "wasm-pack build --target web --out-dir pkg-web --release",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler --release",
    "build:node": "wasm-pack build --target nodejs --out-dir pkg-node --release",
    "test": "wasm-pack test --node"
  },
  "files": [
    "pkg-web",
    "pkg-bundler",
    "pkg-node"
  ],
  "exports": {
    ".": {
      "node": "./pkg-node/nox_wasm.js",
      "import": "./pkg-bundler/nox_wasm.js",
      "require": "./pkg-bundler/nox_wasm.js",
      "types": "./nox_wasm.d.ts"
    },
    "./web": {
      "import": "./pkg-web/nox_wasm.js",
      "types": "./nox_wasm.d.ts"
    }
  },
  "main": "./pkg-node/nox_wasm.js",
  "types": "./nox_wasm.d.ts"
}
